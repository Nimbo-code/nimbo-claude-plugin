{
  "description": "Nimbo plugin lifecycle hooks — detects environment on session start",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-environment.sh",
            "timeout": 15,
            "statusMessage": "Detecting Nimbo environment..."
          }
        ]
      }
    ]
  }
}
